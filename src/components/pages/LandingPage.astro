---
import Layout from '../../layouts/Layout.astro';
import PortfolioSection from '../sections/PortfolioSection.astro';
import ServicesSection from '../sections/ServicesSection.astro';
import AboutSection from '../sections/AboutSection.astro';
import ContactSection from '../sections/ContactSection.astro';
import Footer from '../Footer.astro';
import VideoModal from '../VideoModal';
import { ArrowDown, Play } from 'lucide-react';
import { ui, defaultLang } from '../../i18n/ui';

interface Props {
  lang: keyof typeof ui;
}

const { lang } = Astro.props;
const t = ui[lang] || ui[defaultLang];
---

<Layout title="Claesen Verlichting - Licensed Engineering" lang={lang}>
  
  {/* Hero Section */}
  <section id="home" class="relative min-h-[100svh] w-full flex items-center justify-center overflow-hidden bg-obsidian transition-colors duration-700 pt-24 md:pt-0">
    
    {/* Static Background Image */}
    <div id="hero-bg-image" 
         class="absolute inset-0 z-0 bg-cover bg-center transition-opacity duration-1000 ease-in-out" 
         style="background-image: url('/v1/hero-bg.jpg');">
    </div>

    {/* Video Background (Initially Hidden) */}
    <video
        id="hero-video"
        class="absolute inset-0 z-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000 ease-in-out"
        loop
        muted
        playsinline
        preload="auto"
    >
        <source src="/v1/hero-video.mp4" type="video/mp4" />
    </video>

    {/* Background Overlay */}
    <div class="absolute inset-0 z-0 bg-obsidian/60 lg:bg-obsidian/40 pointer-events-none"></div>
    
    {/* Background Noise/Grid */}
    <div class="absolute inset-0 z-0 opacity-20 mix-blend-overlay pointer-events-none"
         style={{
           backgroundImage: 'url("data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")',
           maskImage: 'radial-gradient(circle at center, black, transparent 80%)'
         }}
    ></div>

    {/* Seamless Bottom Fade */}
    <div class="absolute bottom-0 left-0 w-full h-64 bg-gradient-to-t from-obsidian via-obsidian/80 to-transparent z-[5] pointer-events-none"></div>

    {/* Media Toggle Button (Right Side) */}
    <div class="absolute right-6 bottom-12 md:top-1/2 md:-translate-y-1/2 z-20 flex flex-col items-center gap-2">
        <button id="media-toggle" class="group relative w-12 h-12 flex items-center justify-center rounded-full border border-white/10 bg-white/5 backdrop-blur-md hover:bg-white/10 hover:scale-110 transition-all duration-300">
            {/* Icons handled by script/CSS or explicit SVG swap */}
            <div id="icon-video" class="transition-opacity duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-lux-gold"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>
            </div>
            <div id="icon-image" class="absolute opacity-0 transition-opacity duration-300">
                 <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
            </div>
            
            {/* Tooltip */}
            <span class="absolute right-full mr-4 px-2 py-1 bg-black/80 text-white text-xs rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">
                {lang === 'nl' ? 'Wissel Weergave' : (lang === 'fr' ? 'Changer Vue' : 'Switch View')}
            </span>
        </button>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
      <div class="hidden md:inline-flex mb-4 items-center gap-2 px-3 py-1 rounded-full border border-lux-gold/30 bg-lux-gold/10 text-lux-gold text-xs tracking-wider uppercase animate-fade-in-up">
        <span class="w-1.5 h-1.5 rounded-full bg-lux-gold animate-pulse"></span>
        New v4 Design System
      </div>

      <h1 class="font-display text-4xl md:text-8xl font-bold tracking-tighter mb-4 md:mb-6 relative">
        <span class="block text-transparent bg-clip-text bg-gradient-to-b from-white to-white/50" style="text-shadow: 0 0 40px rgba(255,255,255,0.1);">
          {t['hero.title'] || 'ENGINEERING LUMINOUS'}
        </span>
      </h1>

      <p class="hidden md:block text-white/80 text-base md:text-xl max-w-2xl mx-auto leading-relaxed mb-8 md:mb-10 font-medium drop-shadow-lg px-4" style="text-shadow: 0 2px 10px rgba(0,0,0,0.5);">
        {t['hero.subtitle']}
      </p>

      <div class="flex flex-col md:flex-row items-center justify-center gap-6">
        <a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/#projects`} class="group relative px-8 py-4 bg-lux-gold text-obsidian font-bold rounded-full overflow-hidden transition-transform hover:scale-105">
          <span class="relative z-10 flex items-center gap-2">
            {t['hero.explore']} <ArrowDown className="w-4 h-4 group-hover:translate-y-1 transition-transform" />
          </span>
          <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
        </a>

        <button id="showreel-btn" class="px-8 py-4 rounded-full border border-white/10 hover:bg-white/5 transition-colors flex items-center gap-3 group">
          <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center group-hover:scale-110 transition-transform">
            <Play className="w-3 h-3 fill-current ml-0.5" />
          </div>
          <span>{t['hero.showreel']}</span>
        </button>
      </div>
    </div>
  </section>

<script>
    document.addEventListener('astro:page-load', () => {
        // Logic for Media Toggle (Same as before)
        const toggleBtn = document.getElementById('media-toggle');
        const heroBg = document.getElementById('hero-bg-image');
        const heroVideo = document.getElementById('hero-video') as HTMLVideoElement;
        const iconVideo = document.getElementById('icon-video');
        const iconImage = document.getElementById('icon-image');

        if (toggleBtn && heroBg && heroVideo && iconVideo && iconImage) {
            let isVideoPlaying = !heroVideo.paused && heroVideo.style.opacity !== '0';

            toggleBtn.addEventListener('click', () => {
                const isVideoVisible = heroVideo.style.opacity === '1';

                if (isVideoVisible) {
                    heroVideo.style.opacity = '0';
                    heroBg.style.opacity = '1';
                    setTimeout(() => heroVideo.pause(), 1000);
                    iconVideo.style.opacity = '1';
                    iconImage.style.opacity = '0';
                } else {
                    heroVideo.play().catch(e => console.log("Video autoplay failed", e));
                    heroVideo.style.opacity = '1';
                    heroBg.style.opacity = '0';
                    iconVideo.style.opacity = '0';
                    iconImage.style.opacity = '1';
                }
            });
        } // Closed the media toggle if statement

        // Logic for Showreel Button Event
        const showreelBtn = document.getElementById('showreel-btn');
        if (showreelBtn) {
            showreelBtn.addEventListener('click', () => {
                window.dispatchEvent(new CustomEvent('open-showreel'));
            });
        }
    });
</script>

  <PortfolioSection lang={lang} />
  <ServicesSection lang={lang} />
  <AboutSection lang={lang} />
  <ContactSection lang={lang} />
  <Footer lang={lang} />

  <VideoModal client:load videoUrl={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/hero-video.mp4`} />
</Layout>
